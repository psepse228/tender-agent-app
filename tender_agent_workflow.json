    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Aggregate all saved tenders into one Telegram message\nconst items = $input.all();\nconst tenders = items\n  .map(i => i.json)\n  .filter(t => t.title && t.title !== 'NO_TENDERS_FOUND')\n  .sort((a, b) => (b.matchPercent || 0) - (a.matchPercent || 0));\n\nif (!tenders.length) {\n  return [{ json: { message: '🤖 *Tender Agent*\\n\\nСегодня тендеров не найдено.' } }];\n}\n\nconst submitCount = tenders.filter(t => (t.recommendation || '').includes('Подать')).length;\nconst avgScore = Math.round(tenders.reduce((s, t) => s + (t.matchPercent || 0), 0) / tenders.length);\n\nlet msg = `🤖 *Tender Agent* — ежедневная сводка\\n`;\nmsg += `📊 Найдено: *${tenders.length}* | К подаче: *${submitCount}* | Ср. балл: *${avgScore}%*\\n`;\nmsg += `━━━━━━━━━━━━━━━━━\\n\\n`;\n\nconst top = tenders.slice(0, 10);\nfor (const t of top) {\n  const emoji = t.matchPercent >= 70 ? '🟢' : t.matchPercent >= 40 ? '🟡' : '🔴';\n  msg += `${emoji} *${(t.title || '').slice(0, 80)}*\\n`;\n  if (t.organization) msg += `   🏢 ${t.organization}\\n`;\n  if (t.budget) msg += `   💰 ${t.budget}\\n`;\n  if (t.deadline) msg += `   📅 до ${t.deadline}\\n`;\n  msg += `   Балл: *${t.matchPercent}%* — ${t.recommendation}\\n`;\n  if (t.source && t.source.startsWith('http')) msg += `   🔗 ${t.source}\\n`;\n  msg += '\\n';\n}\n\nif (tenders.length > 10) {\n  msg += `_...и ещё ${tenders.length - 10} тендеров в базе_\\n`;\n}\n\nreturn [{ json: { message: msg } }];"
      },
