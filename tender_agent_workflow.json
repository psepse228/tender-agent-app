    {
      "parameters": {
        "jsCode": "// Reads from OpenAI 'Message a model' node output format\nconst raw = $input.first().json;\nconst text = raw.output?.[0]?.content?.[0]?.text\n  || raw.choices?.[0]?.message?.content\n  || '[]';\n\nlet tenders = [];\ntry {\n  // Extract JSON array from response\n  const match = text.match(/\\[[\\s\\S]*\\]/);\n  if (match) tenders = JSON.parse(match[0]);\n} catch (e) {\n  console.log('Parse error:', e.message, 'Raw:', text.slice(0, 200));\n}\n\nif (!tenders.length) {\n  return [{ json: { _empty: true, title: 'NO_TENDERS_FOUND' } }];\n}\n\nreturn tenders\n  .filter(t => t.title && t.title !== 'NO_TENDERS_FOUND')\n  .map(t => ({ json: t }));"
      },
